{
  "environments": {
    "development": {
      "name": "development",
      "api_url": "http://localhost:3000",
      "database": {
        "host": "localhost",
        "port": 5432,
        "name": "petshop_dev",
        "ssl": false,
        "pool_size": 10
      },
      "redis": {
        "host": "localhost",
        "port": 6379,
        "db": 0
      },
      "logging": {
        "level": "debug",
        "format": "pretty"
      },
      "features": {
        "enable_analytics": false,
        "enable_caching": true,
        "enable_email_notifications": false
      }
    },
    "staging": {
      "name": "staging",
      "api_url": "https://staging-api.petshop.com",
      "database": {
        "host": "staging-db.petshop.com",
        "port": 5432,
        "name": "petshop_staging",
        "ssl": true,
        "pool_size": 20
      },
      "redis": {
        "host": "staging-redis.petshop.com",
        "port": 6379,
        "db": 0,
        "password_required": true
      },
      "logging": {
        "level": "info",
        "format": "json"
      },
      "features": {
        "enable_analytics": true,
        "enable_caching": true,
        "enable_email_notifications": true
      },
      "rate_limiting": {
        "enabled": true,
        "requests_per_minute": 100
      }
    },
    "production": {
      "name": "production",
      "api_url": "https://api.petshop.com",
      "database": {
        "host": "prod-db-primary.petshop.com",
        "port": 5432,
        "name": "petshop_production",
        "ssl": true,
        "pool_size": 50,
        "read_replicas": [
          "prod-db-replica-1.petshop.com",
          "prod-db-replica-2.petshop.com"
        ]
      },
      "redis": {
        "host": "prod-redis-cluster.petshop.com",
        "port": 6379,
        "db": 0,
        "password_required": true,
        "cluster_mode": true
      },
      "logging": {
        "level": "warn",
        "format": "json",
        "external_service": {
          "enabled": true,
          "endpoint": "https://logs.petshop.com"
        }
      },
      "features": {
        "enable_analytics": true,
        "enable_caching": true,
        "enable_email_notifications": true,
        "enable_cdn": true
      },
      "rate_limiting": {
        "enabled": true,
        "requests_per_minute": 1000
      },
      "cdn": {
        "enabled": true,
        "endpoint": "https://cdn.petshop.com"
      },
      "security": {
        "ssl_enabled": true,
        "force_https": true
      }
    }
  }
}
