{
  "monitoring": {
    "enabled": true,
    "prometheus": {
      "scrape_interval": "15s",
      "evaluation_interval": "15s",
      "external_labels": {
        "cluster": "petshop-production",
        "environment": "production"
      }
    },
    "metrics": {
      "application": {
        "http_requests_total": {
          "type": "counter",
          "description": "Total HTTP requests",
          "labels": ["method", "endpoint", "status"]
        },
        "http_request_duration_seconds": {
          "type": "histogram",
          "description": "HTTP request duration",
          "buckets": [0.1, 0.5, 1.0, 2.0, 5.0]
        },
        "active_users": {
          "type": "gauge",
          "description": "Number of active users"
        },
        "orders_total": {
          "type": "counter",
          "description": "Total orders processed"
        }
      },
      "system": {
        "cpu_usage_percent": {
          "type": "gauge",
          "description": "CPU usage percentage"
        },
        "memory_usage_bytes": {
          "type": "gauge",
          "description": "Memory usage in bytes"
        },
        "disk_usage_percent": {
          "type": "gauge",
          "description": "Disk usage percentage"
        }
      }
    },
    "alerts": {
      "high_error_rate": {
        "condition": "rate(http_requests_total{status=~'5..'}[5m]) > 0.05",
        "severity": "critical",
        "description": "High error rate detected",
        "action": "page_oncall"
      },
      "high_response_time": {
        "condition": "http_request_duration_seconds{quantile='0.95'} > 2",
        "severity": "warning",
        "description": "95th percentile response time exceeds 2 seconds",
        "action": "notify_team"
      },
      "low_disk_space": {
        "condition": "disk_usage_percent > 85",
        "severity": "warning",
        "description": "Disk usage exceeds 85%",
        "action": "notify_ops"
      },
      "database_connection_errors": {
        "condition": "rate(database_connection_errors[5m]) > 0",
        "severity": "critical",
        "description": "Database connection errors detected",
        "action": "page_oncall"
      }
    },
    "dashboards": {
      "main": {
        "title": "Pet Shop Main Dashboard",
        "panels": [
          {
            "title": "Request Rate",
            "type": "graph",
            "query": "rate(http_requests_total[5m])"
          },
          {
            "title": "Error Rate",
            "type": "graph",
            "query": "rate(http_requests_total{status=~'5..'}[5m])"
          },
          {
            "title": "Response Time (p95)",
            "type": "graph",
            "query": "histogram_quantile(0.95, http_request_duration_seconds)"
          },
          {
            "title": "Active Users",
            "type": "singlestat",
            "query": "active_users"
          }
        ]
      }
    },
    "log_aggregation": {
      "enabled": true,
      "retention_days": 30,
      "indexes": {
        "application_logs": {
          "pattern": "petshop-*",
          "fields": ["timestamp", "level", "message", "service", "trace_id"]
        },
        "access_logs": {
          "pattern": "access-*",
          "fields": ["timestamp", "method", "path", "status", "duration"]
        }
      }
    },
    "tracing": {
      "enabled": true,
      "sample_rate": 0.1,
      "exporter": "jaeger",
      "endpoint": "http://jaeger:14268/api/traces"
    }
  }
}
